    "claude-code-hooks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsingjui/pi-hooks.git"
  },
  "bugs": {
    "url": "https://github.com/hsingjui/pi-hooks/issues"
  },
  "homepage": "https://github.com/hsingjui/pi-hooks#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
